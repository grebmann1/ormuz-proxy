# Ormuz environment overrides. Loaded automatically from .env in the CWD
# at startup. All values are optional — config/provider-targets.json is
# auto-loaded if present, and CLI flags override anything set here.

ORMUZ_PORT=8787

# Optional fallback upstream when no provider/route matches.
# ORMUZ_UPSTREAM_BASE_URL=https://your-llm-gateway.example.com
# ORMUZ_UPSTREAM_TOKEN=

# Override provider routing. Leave both blank to auto-load
# config/provider-targets.json.
# ORMUZ_PROVIDER_TARGETS={"openai":"https://api.openai.com"}
# ORMUZ_PROVIDER_TARGETS_FILE=

ORMUZ_RPM=60
ORMUZ_SAFETY_FACTOR=0.95
ORMUZ_BUCKET_KEY=auth
ORMUZ_MAX_QUEUE_DEPTH=200
ORMUZ_MAX_QUEUE_WAIT_MS=60000
# ORMUZ_MAX_RETRY_AFTER_MS=5000
ORMUZ_LOG_LEVEL=info
