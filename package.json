{
  "name": "ormuz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Client-side LLM forward proxy with adaptive rate limiting and queueing",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "tsx watch src/cli.ts",
    "dev:cli": "tsx src/cli.ts",
    "load:test": "node scripts/load-test-ormuz.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test",
    "install:autostart": "bash scripts/install-autostart.sh",
    "uninstall:autostart": "bash scripts/uninstall-autostart.sh",
    "install:systemproxy": "bash scripts/install-systemproxy.sh",
    "uninstall:systemproxy": "bash scripts/uninstall-systemproxy.sh",
    "deploy:heroku": "bash scripts/deploy-heroku.sh"
  },
  "bin": {
    "ormuz": "dist/cli.js"
  },
  "dependencies": {
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "undici": "^7.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.31.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
